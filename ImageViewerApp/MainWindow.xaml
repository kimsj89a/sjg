<Window x:Class="ImageViewerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Lightweight Image Studio" Height="800" Width="1200" Background="#FF1E1E1E" Foreground="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#FF2C2C2C" Padding="12" BorderBrush="#FF3A3A3A" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Open Image" Padding="10,6" Click="OnOpenImageClicked"/>
                <Separator Width="12"/>
                <Button Content="⟲ Rotate Left" Padding="10,6" Click="OnRotateLeftClicked"/>
                <Button Content="⟳ Rotate Right" Padding="10,6" Click="OnRotateRightClicked"/>
                <Separator Width="12"/>
                <ToggleButton x:Name="DrawToggle" Content="✎ Draw" Padding="10,6" Checked="OnDrawToggleChanged" Unchecked="OnDrawToggleChanged"/>
                <Button Content="Clear Drawings" Padding="10,6" Click="OnClearDrawingsClicked"/>
                <Separator Width="12"/>
                <ToggleButton x:Name="CropToggle" Content="▭ Crop" Padding="10,6" Checked="OnCropToggleChanged" Unchecked="OnCropToggleChanged"/>
                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Text="Tip: Hold and drag to draw or to choose a crop area." Foreground="#BFBFBF"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="12" Background="#FF121212" BorderBrush="#FF2D2D2D" BorderThickness="1">
            <ScrollViewer x:Name="ImageScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid x:Name="WorkspaceRoot" Background="#FF1C1C1C">
                    <Image x:Name="MainImage" Stretch="None" />
                    <InkCanvas x:Name="DrawingCanvas" Background="Transparent" IsEnabled="False" />
                    <Rectangle x:Name="CropRectangle"
                               Stroke="#FF4FC3F7"
                               StrokeDashArray="4,2"
                               Fill="#334FC3F7"
                               Visibility="Collapsed"
                               IsHitTestVisible="False"/>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
